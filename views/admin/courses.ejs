<%- include('_header') %>

<% if (success && success.length) { %><div class="alert alert-success"><%= success %></div><% } %>
<% if (error && error.length) { %><div class="alert alert-error"><%= error %></div><% } %>

<div class="two-col">
  <!-- Add Course -->
  <div class="card">
    <div class="card-header"><h3>Add Course</h3></div>
    <form action="/admin/courses/add" method="POST" enctype="multipart/form-data">
      <div class="form-group">
        <label>Course Name</label>
        <input type="text" name="name" placeholder="Course name" required>
      </div>
      <div class="form-group">
        <label>Level</label>
        <select name="level" required>
          <option value="">Select level</option>
          <option value="Beginner">Beginner</option>
          <option value="Intermediate">Intermediate</option>
          <option value="Advanced">Advanced</option>
        </select>
      </div>
      <div class="form-group">
        <label>Description</label>
        <textarea name="description" placeholder="Course description" rows="3"></textarea>
      </div>
      <div class="form-group">
        <label>Course Image</label>
        <input type="file" name="image" accept="image/*">
      </div>
      <button type="submit" class="btn btn-primary btn-full">Add Course</button>
    </form>
  </div>

  <!-- Courses List -->
  <div class="card">
    <div class="card-header"><h3>All Courses (<%= courses.length %>)</h3></div>
    <% if (courses.length === 0) { %>
      <div class="empty-state">No courses yet.</div>
    <% } else { %>
      <div class="course-list">
        <% courses.forEach(c => { %>
        <div class="course-item">
          <% if (c.image) { %>
            <img src="<%= c.image %>" class="course-thumb" alt="">
          <% } else { %>
            <div class="course-thumb-placeholder">📚</div>
          <% } %>
          <div class="course-info">
            <strong><%= c.name %></strong>
            <span class="badge badge-<%= c.level.toLowerCase() %>"><%= c.level %></span>
            <p><%= c.description || '' %></p>
            <div class="course-actions">
              <a href="/admin/courses/<%= c._id %>/batches" class="btn btn-sm btn-outline">
                Manage Batches (<%= c.batches.length %>)
              </a>
              <form action="/admin/courses/delete/<%= c._id %>" method="POST" onsubmit="return confirm('Delete this course?')" style="display:inline">
                <button class="btn btn-sm btn-danger">Delete</button>
              </form>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</div>

<%- include('_footer') %>
