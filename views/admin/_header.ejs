<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Ideamagix LMS</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="app-body">
<div class="layout">
  <aside class="sidebar">
    <div class="sidebar-logo">
      <h2>idea<span>magix</span></h2>
      <small>Admin Panel</small>
    </div>
    <nav class="sidebar-nav">
      <a href="/admin/dashboard" class="nav-item <%= page==='dashboard'?'active':'' %>">
        <span>📊</span> Dashboard
      </a>
      <a href="/admin/instructors" class="nav-item <%= page==='instructors'?'active':'' %>">
        <span>👨‍🏫</span> Instructors
      </a>
      <a href="/admin/courses" class="nav-item <%= page==='courses'?'active':'' %>">
        <span>📚</span> Courses
      </a>
      <a href="/admin/lectures" class="nav-item <%= page==='lectures'?'active':'' %>">
        <span>📅</span> Assign Lectures
      </a>
    </nav>
    <div class="sidebar-footer">
      <div class="user-info">
        <div class="avatar"><%= user.name[0] %></div>
        <div>
          <div class="user-name"><%= user.name %></div>
          <div class="user-role">Administrator</div>
        </div>
      </div>
      <a href="/logout" class="logout-btn">Logout</a>
    </div>
  </aside>
  <main class="main-content">
    <div class="topbar">
      <h1 class="page-title"><%= title %></h1>
    </div>
    <div class="content-body">
