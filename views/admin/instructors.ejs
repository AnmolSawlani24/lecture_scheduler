<%- include('_header') %>

<% if (success && success.length) { %><div class="alert alert-success"><%= success %></div><% } %>
<% if (error && error.length) { %><div class="alert alert-error"><%= error %></div><% } %>

<div class="two-col">
  <!-- Add Instructor Form -->
  <div class="card">
    <div class="card-header"><h3>Add Instructor</h3></div>
    <form action="/admin/instructors/add" method="POST">
      <div class="form-group">
        <label>Full Name</label>
        <input type="text" name="name" placeholder="Instructor name" required>
      </div>
      <div class="form-group">
        <label>Email</label>
        <input type="email" name="email" placeholder="Email address" required>
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" name="password" placeholder="Set password" required>
      </div>
      <button type="submit" class="btn btn-primary btn-full">Add Instructor</button>
    </form>
  </div>

  <!-- Instructors List -->
  <div class="card">
    <div class="card-header"><h3>All Instructors (<%= instructors.length %>)</h3></div>
    <% if (instructors.length === 0) { %>
      <div class="empty-state">No instructors yet.</div>
    <% } else { %>
    <table class="table">
      <thead><tr><th>Name</th><th>Email</th><th>Action</th></tr></thead>
      <tbody>
        <% instructors.forEach(inst => { %>
        <tr>
          <td><div class="avatar-sm"><%= inst.name[0] %></div> <%= inst.name %></td>
          <td><%= inst.email %></td>
          <td>
            <form action="/admin/instructors/delete/<%= inst._id %>" method="POST" onsubmit="return confirm('Delete this instructor?')">
              <button class="btn btn-sm btn-danger">Delete</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>
</div>

<%- include('_footer') %>
